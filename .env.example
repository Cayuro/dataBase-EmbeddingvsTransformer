# Tipo de base de datos: sqlite, mysql, postgresql
DB_TYPE=postgresql

# URL JDBC de la base de datos
DB_URL=jdbc:postgresql://localhost:5432/vision_mouse

# Credenciales de base de datos
DB_USER=vision_user
DB_PASSWORD=password123

# Pool de conexiones HikariCP
DB_POOL_MAX=5
DB_POOL_MIN=2
DB_CONN_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=300000
